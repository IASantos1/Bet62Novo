{
  "framework": "vite",
  "installCommand": "npx -y pnpm@10.28.1 install --no-frozen-lockfile",
  "buildCommand": "npx -y pnpm@10.28.1 --filter @workspace/bet62 build",
  "outputDirectory": "artifacts/bet62/dist",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
