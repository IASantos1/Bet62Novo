+  const asAge = (t: number) => (t > 0 ? Math.max(0, now - t) : null);
+  res.json({
+    serverTime: now,
+    sportsApiKeyPresent: !!SPORTSAPI_KEY,
+    wsConnected: Array.from(wsConnected),
+    v1WsConnected: Array.from(v1WsConnected),
