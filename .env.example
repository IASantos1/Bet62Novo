# ── Required ─────────────────────────────────────────────────────────────────

# Database connection (auto-provided by Replit; required on Railway/self-hosted)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session secret — generate a strong random string for production
SESSION_SECRET=your-session-secret-here

# Admin panel credentials — server will refuse to start without these
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password
ADMIN_EMAIL=admin@example.com

# ── Payments (required for deposits/withdrawals) ───────────────────────────

STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Optional ──────────────────────────────────────────────────────────────────

# Redis — enables background bet settlement queue (disabled if not set)
REDIS_URL=redis://...

# Sports data API key (statpal.io)
SPORTSAPI_KEY=your-api-key

# Email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@example.com
